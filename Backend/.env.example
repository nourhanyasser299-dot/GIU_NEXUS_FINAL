PORT=5000
NODE_ENV=development

MONGO_URI=mongodb://localhost:27017/giu_nexus

JWT_SECRET=replace_with_minimum_32_char_secret_here
JWT_EXPIRES_IN=7d

OPENAI_API_KEY=sk-replace_with_your_key

# Hugging Face Inference API — used by /api/ai/* endpoints (Milestone 2).
# Optional: most public models answer without a token but with stricter rate
# limits. A free token from https://huggingface.co/settings/tokens raises
# those limits and removes the cold-start 503s.
HF_API_TOKEN=
HF_API_BASE=https://api-inference.huggingface.co
HF_SKILL_MODEL=jjzha/jobbert_skill_extraction
HF_MATCH_MODEL=sentence-transformers/all-MiniLM-L6-v2
HF_SUMMARY_MODEL=sshleifer/distilbart-cnn-12-6

MAX_FILE_SIZE_MB=5
UPLOAD_DIR=uploads/

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
