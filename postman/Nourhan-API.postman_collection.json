    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /api/auth/register (seeker)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Demo Seeker\",\n  \"email\": \"{{seekerEmail}}\",\n  \"password\": \"{{seekerPassword}}\",\n  \"role\": \"seeker\"\n}"
            },
            "description": "Public. Registers a job seeker.\n\n**Body:** `{ name, email, password, role: \"seeker\" }`.\n\n**Expected:** `201 { success: true, data: { token, user } }`. Test script saves `data.token` into the `token` collection variable so subsequent authenticated requests work without copy-pasting headers."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const j = pm.response.json();",
                  "pm.test('Status 201 or 409 (already registered)', () => pm.expect([201, 409]).to.include(pm.response.code));",
                  "if (pm.response.code === 201 && j && j.data && j.data.token) {",
                  "  pm.collectionVariables.set('token', j.data.token);",
                  "  console.log('[postman] saved seeker token to collection variable');",
                  "}"
                ]
              }
            }
          ]
        },
