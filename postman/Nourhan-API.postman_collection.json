{
  "info": {
    "_postman_id": "8b4a2f1e-1c7a-4a3d-92f2-2f1a3d4e5b6c",
    "name": "GIU Nexus API",
    "description": "Manual API testing collection for the GIU Nexus backend (HusseinSelim-1977/Nourhan_Project).\n\nCovers every route under `/api`: health, auth, jobs, applications, seeker, recruiter, admin, and the three Hugging Face AI endpoints.\n\n**JWT auto-attach.** Collection-level auth is set to Bearer `{{token}}`. The Login and Register requests run a test script that pulls `data.token` out of the response body and stores it in the `token` collection variable, so every subsequent authenticated request just works without copy-pasting headers.\n\n**Pair this with the Local Dev environment** (`Nourhan-API.postman_environment.json`) for `baseUrl` and seed credentials.\n\nThis collection is **complementary** to the existing Jest + Supertest unit tests (`Backend/__tests__/`) and the Playwright E2E runner (`tests/e2e/run-tests.js`) — it does not replace them. Use Postman for manual exploration, demos, and one-off poking; the automated tests still run on every PR.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{token}}", "type": "string" }
    ]
  },
  "variable": [
    { "key": "token", "value": "", "type": "string" },
    { "key": "jobId", "value": "", "type": "string" },
    { "key": "applicationId", "value": "", "type": "string" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Collection-level pre-request: nothing needed.",
          "// JWT auto-attach is handled by collection-level Bearer auth using {{token}},",
          "// which is populated by the Login / Register requests' test scripts."
        ]
      }
    }
  ],
